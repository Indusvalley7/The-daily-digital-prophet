# Backend Configuration
# ---------------------

# Supabase (Relational DB for articles, summaries, and metadata)
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key

# ChromaDB (Vector DB for Semantic Search)
# For MVP, we will use a local ChromaDB instance that stores data in /chroma_data
CHROMA_DB_DIR=./chroma_data

# LLM Configuration
# Set LLM_PROVIDER to "groq" for instant cloud inference or "ollama" for slow, local hardware.
LLM_PROVIDER=groq
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral

# If LLM_PROVIDER is "groq", provide a free API key from https://console.groq.com
GROQ_API_KEY=your-groq-api-key
